model PlayerStats {
    id String @id @default(uuid())

    kills  Int @default(0)
    deaths Int @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId])
    @@index([kills])
    @@map("player_stats")
}
